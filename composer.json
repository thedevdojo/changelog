{
    "name": "devdojo/changelog",
    "description": "A drop-in changelog feature (model, admin resource, read-tracking) for Laravel applications.",
    "keywords": ["devdojo", "changelog", "laravel"],
    "homepage": "https://github.com/devdojo/changelog",
    "license": "MIT",
    "type": "library",
    "version": "0.0.1",
    "authors": [
        {
            "name": "Tony Lea",
            "email": "tony@devdojo.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "filament/filament": "Required to use the bundled Changelog admin resource (ChangelogPlugin)."
    },
    "autoload": {
        "psr-4": {
            "Devdojo\\Changelog\\": "src"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devdojo\\Changelog\\ChangelogServiceProvider"
            ]
        }
    }
}
